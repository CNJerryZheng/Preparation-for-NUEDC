{
    // 使用 IntelliSense 了解相关属性。
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "probe-rs-debug",
            "request": "launch",
            "name": "probe-rs Debug (MSPM0G3507)",
            "cwd": "${workspaceFolder}",
            "connectUnderReset": false,
            "chip": "MSPM0G3507",
            "flashingConfig": {
                "flashingEnabled": true,
                "haltAfterReset": false
            },
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "build/MSPA.elf"
                }
            ]
        },
        {
            "name": "Cortex-Debug (DAP-Link + MSPM0G3507)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/MSPA.elf",
            "request": "launch",
            "svdFile": "${workspaceFolder}/svd/mspm0g350x.svd",
            // "svdFile": "${workspaceFolder}/svd/Cortex-M0plus.svd",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
            "type": "cortex-debug",
            "servertype": "openocd",
            "serverpath": "${config:ti-embedded-debug.openocdExecutablePath}",
            "searchDir": [
                "${config:ti-embedded-debug.openocdSearchPath}"
            ],
            "configFiles": [
                "${workspaceFolder}/openocd.cfg"
            ],
            "deviceName": "MSPM0G3507",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw"
        }
    ]
}