{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "MSPM0: Build",
            "type": "process",
            "command": "ninja",
            "args": [
                "-C",
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "MSPM0: Download",
            "type": "process",
            "command": "probe-rs",
            "args": [
                "download",
                "--chip",
                "MSPM0G3507",
                "--verify",
                "${workspaceFolder}/build/empty.elf"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "MSPM0: Reset & Run",
            "type": "process",
            "command": "probe-rs",
            "args": [
                "reset",
                "--chip",
                "MSPM0G3507"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "MSPM0: Build, Flash & Run",
            "dependsOrder": "sequence",
            "dependsOn": [
                "MSPM0: Build",
                "MSPM0: Download",
                "MSPM0: Reset & Run"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "MSPM0: Open SysConfig GUI",
            "type": "process",
            "command": "${input:sysconfigGui}",
            "args": [
                "-s",
                "${input:mspm0ProductJson}",
                "-d",
                "MSPM0G3507",
                "-p",
                "LQFP-48(PT)",
                "${workspaceFolder}/Core/empty.syscfg"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "never"
            }
        }
    ],
    "inputs": [
        {
            "id": "sysconfigGui",
            "type": "promptString",
            "description": "本机 sysconfig_gui.bat 路径",
            "default": "D:/ti/SYSCONFIG/sysconfig_gui.bat"
        },
        {
            "id": "mspm0ProductJson",
            "type": "promptString",
            "description": "本机 MSPM0 SDK product.json 路径",
            "default": "D:/ti/MSPM0_SDK/mspm0_sdk_2_02_00_05/.metadata/product.json"
        }
    ]
}
