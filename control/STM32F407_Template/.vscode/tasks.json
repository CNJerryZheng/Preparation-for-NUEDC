{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Generate HEX from ELF",
            "type": "shell",
            "command": "arm-none-eabi-objcopy",
            "args": [
                "-O",
                "ihex",
                "${workspaceFolder}/build/debug/Study.elf", // 输入ELF文件路径
                "${workspaceFolder}/build/debug/Study.hex" // 输出HEX文件路径
            ],
            "group": "none",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Convert ELF to HEX format for STM32 programming"
        }
    ]
}